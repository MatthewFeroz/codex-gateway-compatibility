+@pytest.mark.asyncio
+async def test_openai_responses_completed_has_usage_when_native_stream_omits_it():
+    """Codex requires all usage counters on response.completed."""
+    import json as _json
+    from unittest.mock import MagicMock, patch as _patch
+
+    from merge_gateway.api.routes import sdk_compat_openai
+
+    async def fake_stream(*_args, **_kwargs):
+        data = {
+            "object": "response.done",
+            "output": [
+                {
+                    "content": [{"type": "text", "text": "Hello"}],
+                    "finish_reason": "stop",
+                }
+            ],
+        }
+        yield f"data: {_json.dumps(data)}\n\n"
+
+    with _patch.object(sdk_compat_openai, "stream_response", fake_stream):
+        out = [
+            line
+            async for line in sdk_compat_openai._stream_responses(
+                MagicMock(), MagicMock(), MagicMock(), "openai/gpt-5.6-sol"
+            )
+        ]
+
+    events = [
+        _json.loads(line[6:].strip())
+        for line in out
+        if line.startswith("data: ")
+    ]
+    completed = events[-1]
+    assert completed["type"] == "response.completed"
+    assert completed["response"]["usage"] == {
+        "input_tokens": 0,
+        "output_tokens": 0,
+        "total_tokens": 0,
+    }
+
+
